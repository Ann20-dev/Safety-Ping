AFRICASTALKING_ENVIRONMENT=sandbox
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_SHORTCODE=79064

# The code also accepts these names from your SMS echo sample:
# SANDBOX_USERNAME=sandbox
# SANDBOX_API_KEY=your_api_key_here
# SMS_SHORTCODE=79064
# AT_MESSAGING_URL=https://api.sandbox.africastalking.com/version1/messaging

# Production bulk SMS only. Sandbox does not require a sender ID.
AFRICASTALKING_SENDER_ID=

# Premium/two-way SMS only.
AFRICASTALKING_KEYWORD=

# Set false to queue dashboard alerts without sending SMS automatically.
SAFETYPING_SMS_AUTO_SEND=true

# Set true to test the app without calling Africa's Talking.
SAFETYPING_SMS_DRY_RUN=false

LOG_LEVEL=INFO
